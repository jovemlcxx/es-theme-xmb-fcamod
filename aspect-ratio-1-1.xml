<theme>
   <formatVersion>7</formatVersion>
   <view name="screen">
      <text name="clock">
         <pos>0.75 0.02</pos>
         <size>0.23 0.05</size>
         <fontSize>0.035</fontSize>
         <color>ffffff</color>
         <alignment>right</alignment>
         <fontPath>./_inc/fonts/FOT-NewRodin Pro DB.otf</fontPath>
      </text>
      <batteryIndicator name="batteryIndicator">
         <pos>0.027 0.02</pos>
         <size>0.10 0.05</size>
         <fontSize>0.03</fontSize>
         <color>ffffff</color>
      </batteryIndicator>
   </view>
   <include subset="layout" name="vertical">./_inc/layouts/vertical-1-1.xml</include>

   <view name="system">
   </view>

   <view name="system, grid">
      <image name="bg_image" extra="true">
         <pos>-0.005 -0.005</pos>
         <size>1.01 1.01</size>
      </image>
      <video name="bg_video" extra="true">
         <pos>-0.005 -0.005</pos>
         <size>1.01 1.01</size>
      </video>
   </view>

   <view name="system">
      <image name="background_overlay" extra="true">
         <pos>-0.005 -0.005</pos>
         <size>1.01 1.01</size>
         <color>00000033</color>
         <zIndex>5</zIndex>
      </image>
      <carousel name="systemcarousel">
         <type>horizontal</type>
         <logoAlignment>center</logoAlignment>
         <pos>-0.30 0.27</pos>
         <size>1.3 0.2</size>
         <logoSize>0.15 0.15</logoSize>
         <maxLogoCount>5</maxLogoCount>
         <defaultTransition>instant</defaultTransition>
         <origin>0 0</origin>
      </carousel>
      <image name="e_system_content" extra="true">
         <pos>0.35 0.56</pos>
         <maxSize>0.12 0.16</maxSize>
         <origin>0.5 0.5</origin>
      </image>
      <text name="e_system_name" extra="true">
         <pos>0.42 0.49</pos>
         <size>0.55 0.06</size>
         <fontSize>0.06</fontSize>
      </text>
      <image name="e_metadata_line" extra="true">
         <pos>0.42 0.57</pos>
         <size>0.60 0.002</size>
      </image>
      <text name="systemInfo">
         <pos>0.42 0.59</pos>
         <size>0.55 0.05</size>
         <fontSize>0.03</fontSize>
      </text>
   </view>
   <view name="system,grid">
      <helpsystem name="help">
         <pos>0.027 0.920</pos>
         <iconColor>00000000</iconColor>
         <textColor>00000000</textColor>
      </helpsystem>
      <image name="e_help_start_icon" extra="true">
         <path>./_inc/images/help-button-start-XBOX.svg</path>
         <pos>0.027 0.95</pos>
         <maxSize>0.045 0.05</maxSize>
         <origin>0 0.5</origin>
         <color>ffffffcc</color>
         <zIndex>90</zIndex>
      </image>
      <text name="e_help_start_text" extra="true">
         <text>${helpMenu}</text>
         <pos>0.08 0.95</pos>
         <size>0.20 0.05</size>
         <fontSize>0.035</fontSize>
         <color>ffffffcc</color>
         <fontPath>./_inc/fonts/FOT-NewRodin Pro DB.otf</fontPath>
         <alignment>left</alignment>
         <verticalAlignment>center</verticalAlignment>
         <origin>0 0.5</origin>
         <zIndex>90</zIndex>
      </text>
      <image name="e_help_a_icon" extra="true">
         <path>./_inc/images/help-button-a-switch.svg</path>
         <pos>0.973 0.95</pos>
         <maxSize>0.045 0.05</maxSize>
         <origin>1 0.5</origin>
         <color>ffffffcc</color>
         <zIndex>90</zIndex>
      </image>
      <text name="e_help_a_text" extra="true">
         <text>${helpSelect}</text>
         <pos>0.92 0.95</pos>
         <size>0.42 0.05</size>
         <fontSize>0.035</fontSize>
         <color>ffffffcc</color>
         <fontPath>./_inc/fonts/FOT-NewRodin Pro DB.otf</fontPath>
         <alignment>right</alignment>
         <verticalAlignment>center</verticalAlignment>
         <origin>1 0.5</origin>
         <zIndex>90</zIndex>
      </text>
   </view>
   <view name="grid">
      <image name="logo">
         <pos>2 2</pos>
      </image>
      <imagegrid name="gamegrid">
         <pos>0.02 0.125</pos>
         <size>0.30 0.75</size>
         <padding>0 0 0 0</padding>
         <autoLayout>1 3</autoLayout>
         <scrollDirection>verticalCenter</scrollDirection>
         <centerSelection>true</centerSelection>
         <autoLayoutSelectedZoom>1.0</autoLayoutSelectedZoom>
         <imageSource>marquee</imageSource>
         <folderImage>./_inc/images/xmb_folder.png</folderImage>
         <gameImage>./_inc/images/xmb_game.png</gameImage>
         <zIndex>50</zIndex>
         <scrollSound>./_inc/sounds/scroll.wav</scrollSound>
      </imagegrid>
      <gridtile name="default">
         <size>0.30 0.25</size>
         <padding>0 0</padding>
         <imageSizeMode>maxSize</imageSizeMode>
         <backgroundCenterColor>00000000</backgroundCenterColor>
         <backgroundEdgeColor>00000000</backgroundEdgeColor>
      </gridtile>
      <gridtile name="selected">
         <backgroundCenterColor>00000000</backgroundCenterColor>
         <backgroundEdgeColor>00000000</backgroundEdgeColor>
      </gridtile>
      <text name="md_name">
         <pos>0.40 0.42</pos>
         <size>0.60 0.08</size>
         <fontSize>0.038</fontSize>
         <fontPath>${fontBold}</fontPath>
         <color>ffffff</color>
         <alignment>left</alignment>
         <zIndex>60</zIndex>
      </text>
      <image name="md_line" extra="true">
         <path>${spacerImage}</path>
         <pos>0.40 0.50</pos>
         <size>0.60 0.002</size>
         <color>ffffff88</color>
         <zIndex>55</zIndex>
      </image>
      <text name="md_description">
         <pos>0.40 0.52</pos>
         <size>0.60 0.35</size>
         <fontSize>0.025</fontSize>
         <fontPath>${fontRegular}</fontPath>
         <color>ffffffcc</color>
         <alignment>left</alignment>
         <multiLine>true</multiLine>
         <zIndex>60</zIndex>
      </text>
      <image name="background_overlay" extra="true">
         <pos>-0.005 -0.005</pos>
         <size>1.01 1.01</size>
         <color>0000008C</color>
         <zIndex>5</zIndex>
      </image>
      <image name="md_image">
         <pos>0.5 0.5</pos>
         <minSize>1.01 1.01</minSize>
         <origin>0.5 0.5</origin>
         <zIndex>1</zIndex>
      </image>
      <video name="md_video">
         <pos>0.5 0.5</pos>
         <minSize>1.01 1.01</minSize>
         <origin>0.5 0.5</origin>
         <delay>2.0</delay>
         <zIndex>2</zIndex>
      </video>
   </view>
</theme>
