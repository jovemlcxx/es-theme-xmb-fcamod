   <subset name="aspect-ratio" displayName="${aspectRatioLabel}">
      <include name="4-3" displayName="4:3" />
      <include name="1-1" displayName="1:1" />
   </subset>
   <subset name="background-video" displayName="${videoLabel}">
      <include name="enabled" displayName="${enabledLabel}">
         <variables>
            <showBackgroundVideo>true</showBackgroundVideo>
         </variables>
      </include>
      <include name="disabled" displayName="${disabledLabel}">
         <variables>
            <showBackgroundVideo>false</showBackgroundVideo>
         </variables>
      </include>
   </subset>
   <subset name="wallpaper" displayName="${wallpaperLabel}">
      <include name="1" displayName="1 (default)">./_inc/wallpapers/1.xml</include>
      <include name="2" displayName="2">./_inc/wallpapers/2.xml</include>
      <include name="3" displayName="3">./_inc/wallpapers/3.xml</include>
      <include name="4" displayName="4">./_inc/wallpapers/4.xml</include>
      <include name="5" displayName="5">./_inc/wallpapers/5.xml</include>
      <include name="6" displayName="6">./_inc/wallpapers/6.xml</include>
      <include name="7" displayName="7">./_inc/wallpapers/7.xml</include>
      <include name="8" displayName="8">./_inc/wallpapers/8.xml</include>
      <include name="9" displayName="9">./_inc/wallpapers/9.xml</include>
      <include name="10" displayName="10">./_inc/wallpapers/10.xml</include>
      <include name="11" displayName="11">./_inc/wallpapers/11.xml</include>
      <include name="12" displayName="12">./_inc/wallpapers/12.xml</include>
      <include name="13" displayName="13">./_inc/wallpapers/13.xml</include>
      <include name="14" displayName="14">./_inc/wallpapers/14.xml</include>
      <include name="15" displayName="15">./_inc/wallpapers/15.xml</include>
      <include name="16" displayName="16">./_inc/wallpapers/16.xml</include>
      <include name="17" displayName="17">./_inc/wallpapers/17.xml</include>
      <include name="18" displayName="18">./_inc/wallpapers/18.xml</include>
      <include name="19" displayName="19">./_inc/wallpapers/19.xml</include>
      <include name="20" displayName="20">./_inc/wallpapers/20.xml</include>
   </subset>
   <subset name="layout" displayName="${layoutLabel}">
      <include name="horizontal" displayName="${horizontalLabel}" />
      <include name="vertical" displayName="${verticalLabel}" />
   </subset>
   <view name="system, grid">
      <image name="bg_image" extra="true">
         <path>${wallpaperPath}</path>
         <pos>0 0</pos>
         <size>1 1</size>
         <zIndex>0</zIndex>
      </image>
      <video name="bg_video" extra="true">
         <path>${wallpaperVideoPath}</path>
         <pos>0 0</pos>
         <size>1 1</size>
         <zIndex>1</zIndex>
         <visible>${showBackgroundVideo}</visible>
         <showSnapshotNoVideo>true</showSnapshotNoVideo>
         <showSnapshotDelay>false</showSnapshotDelay>
         <delay>0</delay>
      </video>
   </view>
   <view name="system">
      <image name="background_overlay" extra="true">
         <path>${spacerImage}</path>
         <pos>-0.005 -0.005</pos>
         <size>1.01 1.01</size>
         <color>00000033</color>
         <zIndex>5</zIndex>
      </image>
   </view>
   <view name="grid">
      <image name="background_overlay" extra="true">
         <path>${spacerImage}</path>
         <pos>-0.005 -0.005</pos>
         <size>1.01 1.01</size>
         <color>0000008C</color>
         <zIndex>5</zIndex>
      </image>
   </view>
   <view name="system">
      <carousel name="systemcarousel">
         <type>horizontal</type>
         <logoAlignment>center</logoAlignment>
         <zIndex>40</zIndex>
         <color>00000000</color>
         <maxLogoCount>5</maxLogoCount>
         <logoScale>1.2</logoScale>
         <scrollSound>./_inc/sounds/scroll.wav</scrollSound>
      </carousel>
      <image name="logo">
         <path>${systemCarouselImagePath}/${system.theme}.png</path>
         <default>${systemCarouselImagePath}/_default.png</default>
      </image>
      <image name="e_system_content" extra="true">
         <path>${systemContentImagePath}/${system.theme}.png</path>
         <default>${systemContentImagePath}/_default.png</default>
         <zIndex>45</zIndex>
      </image>
      <text name="e_system_name" extra="true">
         <text>${system.fullName}</text>
         <fontPath>${fontBold}</fontPath>
         <color>ffffff</color>
         <alignment>left</alignment>
         <zIndex>50</zIndex>
      </text>
      <image name="e_metadata_line" extra="true">
         <path>${spacerImage}</path>
         <color>ffffff88</color>
         <zIndex>45</zIndex>
      </image>
      <text name="systemInfo">
         <systemdata>gamecount</systemdata>
         <fontPath>${fontRegular}</fontPath>
         <color>ffffff</color>
         <alignment>left</alignment>
         <zIndex>50</zIndex>
      </text>
   </view>
   <include subset="aspect-ratio" name="4-3">./aspect-ratio-4-3.xml</include>
   <include subset="aspect-ratio" name="1-1">./aspect-ratio-1-1.xml</include>
   <include subset="layout" name="vertical">./_inc/layouts/vertical.xml</include>
</theme>
