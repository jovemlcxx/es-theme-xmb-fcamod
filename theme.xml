      <systemContentImagePath>./_inc/systems/physical-media</systemContentImagePath>
      <spacerImage>./_inc/images/white.png</spacerImage>
      <backgroundImage>./_inc/images/background.png</backgroundImage>
      <helpMenu>MENU</helpMenu>
      <helpSelect>SELECT</helpSelect>
      <aspectRatioLabel>Aspect Ratio</aspectRatioLabel>
      <wallpaperLabel>Wallpaper</wallpaperLabel>
      <layoutLabel>System Layout</layoutLabel>
