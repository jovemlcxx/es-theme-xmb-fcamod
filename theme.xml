<theme defaultView="grid">
   <formatVersion>7</formatVersion>
   <capabilities>
      <suppressGamelistViewStyle>true</suppressGamelistViewStyle>
      <suppressDefaultGridSize>true</suppressDefaultGridSize>
   </capabilities>
